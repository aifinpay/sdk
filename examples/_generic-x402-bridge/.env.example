# ── generic-x402-bridge — front any upstream API via config, no code edits ──
# Copy to .env (or scaffold one: node ../../scripts/new-provider.mjs ...).

PORT=3000
SERVICE_NAME=mybrand-x402-bridge
SERVICE_LABEL=MyBrand AI
SLUG=mybrand

# ── The three per-provider knobs ──
# 1. Where to forward the paid request.
UPSTREAM_URL=https://api.mybrand.example/v1/endpoint
# 2. How to authenticate to the upstream:
#      bearer    → Authorization: Bearer <key>      (OpenAI, Venice, Tavily…)
#      x-api-key → x-api-key: <key>                  (Exa…)
#      header    → <UPSTREAM_AUTH_HEADER>: <key>     (ElevenLabs → xi-api-key)
UPSTREAM_AUTH_STYLE=bearer
UPSTREAM_AUTH_HEADER=authorization
UPSTREAM_API_KEY=
# 3. The path this bridge exposes + forwards, and what to charge.
ROUTE_PATH=/chat/completions
# Optional: reject bodies missing this field (e.g. messages, query, text).
REQUIRE_BODY_FIELD=

# ── Pricing ── (PRICE_WEI is native POL; PRICE_*_UNITS are 6-decimal stables)
PRICE_WEI=15000000000000000
PRICE_USDC_UNITS=10500
PRICE_USDT_UNITS=10500

# ── Settlement ──
BRIDGE_MERCHANT_WALLET=0xD31d82c4b35DABaA2ad7023C89A78A052D1f3c8e
POLYGON_RPC=https://1rpc.io/matic
SPLITTER_ADDRESS_POLYGON=0xE34Fc0E6694821c600Fa0955C0F74720ea6d8440

# Optional Solana settlement (leave BRIDGE_MERCHANT_SOLANA empty to disable).
BRIDGE_MERCHANT_SOLANA=
PRICE_LAMPORTS=100000

# Optional Redis (shared order/tx state across instances). Empty → in-memory.
REDIS_URL=
