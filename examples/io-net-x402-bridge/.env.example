PORT=3003
SERVICE_NAME=io-net-x402-bridge

# io.net IO Intelligence — managed LLM inference on io.net's GPU pool.
# Get the key at https://dashboard.io.net/ (Project = io.intelligence).
IONET_API_KEY=
IONET_API_URL=https://api.intelligence.io.solutions/api/v1/chat/completions
# Most io.net keys use Bearer. If your key needs x-api-key header instead,
# set IONET_AUTH_SCHEME=x-api-key.
IONET_AUTH_SCHEME=bearer

# Merchant wallet — where 98.99% of every paid call lands. Usually the
# AiFinPay treasury Safe for our hosted bridges; partners running their
# own bridge would put their own wallet here.
BRIDGE_MERCHANT_WALLET=0xD31d82c4b35DABaA2ad7023C89A78A052D1f3c8e

# 0.25 POL ≈ $0.025 per inference call. IO Intelligence per-token pricing
# on llama-3-70B class models is ~$0.001-0.005 per typical agent request,
# leaving 5-20× margin. Adjust for your model mix.
PRICE_WEI=250000000000000000

# Polygon RPC for tx receipt verification. publicnode is fine for
# real-time verification (no historical scan needed).
POLYGON_RPC=https://1rpc.io/matic

# Splitter contract — verified deployment, owned by AiFinPay treasury Safe.
SPLITTER_ADDRESS_POLYGON=0xE34Fc0E6694821c600Fa0955C0F74720ea6d8440

# Optional — Redis for order/tx state (shared across bridge instances).
# If unset, falls back to in-memory store (single-process only).
REDIS_URL=
