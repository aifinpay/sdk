# ── Bridge merchant wallet (where per-search revenue lands) ──────────────
# For the pilot we reuse the AiFinPay Gnosis Safe (4-of-N on Polygon mainnet).
# The Safe is also the protocol treasury, so 1% fee + merchant amount both
# land in the same vault — cleanup of bridge-vs-treasury accounting is
# deferred until we onboard external bridge operators.
BRIDGE_MERCHANT_WALLET=0xD31d82c4b35DABaA2ad7023C89A78A052D1f3c8e

# ── Exa AI ───────────────────────────────────────────────────────────────
# Get a key from https://exa.ai (free tier: 1000 searches/month).
EXA_API_KEY=

# ── Agent (demo client) ──────────────────────────────────────────────────
# Generate a fresh disposable EOA:  node gen-test-wallet.js
# Fund the printed address with ~0.05 MATIC, paste the private key here.
AGENT_PRIVATE_KEY=

# ── Pricing ──────────────────────────────────────────────────────────────
# Total MATIC the agent sends per call. Contract splits 98.99/1/0.01 so
# merchant receives ≈ value × 0.9899.
#
# At MATIC ≈ $0.7, 0.015 MATIC ≈ $0.0105 → merchant gets ~$0.0104
# vs. upstream Exa cost $0.005 → ~50% gross margin. Demo pilot setting.
PRICE_WEI=15000000000000000

# ── Polygon RPC ──────────────────────────────────────────────────────────
POLYGON_RPC=https://polygon.drpc.org

# ── Server ───────────────────────────────────────────────────────────────
PORT=3001
SERVICE_NAME=exa-x402-bridge

# ── Splitter contract (Polygon mainnet) ──────────────────────────────────
SPLITTER_ADDRESS_POLYGON=0xE34Fc0E6694821c600Fa0955C0F74720ea6d8440
