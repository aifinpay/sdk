PORT=3002
SERVICE_NAME=venice-x402-bridge

# Venice AI — OpenAI-compatible LLM inference on GPU compute.
# Get the key at https://venice.ai (account settings → API).
VENICE_API_KEY=
VENICE_API_URL=https://api.venice.ai/api/v1/chat/completions

# Merchant wallet — where 98.99% of every paid call lands. Usually the
# AiFinPay treasury Safe for hosted bridges; partners running their own
# bridge put their own wallet here.
BRIDGE_MERCHANT_WALLET=0xD31d82c4b35DABaA2ad7023C89A78A052D1f3c8e

# 0.35 POL ≈ $0.035 per inference call. Venice charges per-token
# (~$0.50/M input + $2/M output for llama-3-70b class). Tune to keep
# 5-20× margin on the bridge.
PRICE_WEI=350000000000000000

POLYGON_RPC=https://1rpc.io/matic
SPLITTER_ADDRESS_POLYGON=0xE34Fc0E6694821c600Fa0955C0F74720ea6d8440

# Optional — Redis for order/tx state (shared across bridge instances).
# If unset, falls back to in-memory store (single-process only).
REDIS_URL=
