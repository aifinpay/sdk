# Gcore Everywhere Inference bridge config — copy to .env and fill in.

# Bridge listen port (default 3004; io-net=3003, exa=3001, venice=3002).
PORT=3004

# Upstream: paste your provisioned Gcore Inference deployment endpoint
# WITH the OpenAI-compatible /v1/chat/completions suffix.
GCORE_API_URL=https://your-deployment.inference.your-region.gcore.cloud/v1/chat/completions

# Gcore IAM API token (Cloud → Everywhere Inference scope).
GCORE_API_KEY=

# Auth scheme: Gcore default = "apikey" (Authorization: APIKey <token>).
# Override to "bearer" or "x-api-key" if your deployment requires it.
GCORE_AUTH_SCHEME=apikey

# Polygon settlement
SPLITTER_ADDRESS_POLYGON=0xE34Fc0E6694821c600Fa0955C0F74720ea6d8440
BRIDGE_MERCHANT_WALLET=

# Pricing — default 0.25 POL (~$0.025) per call. Increase for heavy models
# or longer contexts. Stablecoin alternates: 25000 units = $0.025 USDC/USDT.
PRICE_WEI=250000000000000000
PRICE_USDC_UNITS=25000
PRICE_USDT_UNITS=25000
