{
  "name": "@aifinpay/mcp",
  "version": "0.1.0-alpha.5",
  "description": "Pay-per-call MCP server for autonomous AI agents \u2014 installs in Claude Desktop / Cursor / Continue with one config block; on-chain settlement on Polygon and Solana via x402.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "aifinpay-mcp": "bin/aifinpay-mcp.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mcp-server",
    "claude-desktop",
    "claude-mcp",
    "cursor",
    "windsurf",
    "ai-agent",
    "ai-agents",
    "agentic-ai",
    "autonomous-agents",
    "agent-payments",
    "agent-commerce",
    "x402",
    "payments",
    "crypto-payments",
    "polygon",
    "solana",
    "non-custodial",
    "stripe-for-ai-agents"
  ],
  "author": "CoinSecurities (SECCO) <contact@aifinpay.company>",
  "license": "MIT",
  "homepage": "https://github.com/AiFinPay/sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AiFinPay/sdk.git",
    "directory": "mcp"
  },
  "bugs": "https://github.com/AiFinPay/sdk/issues",
  "dependencies": {
    "@aifinpay/agent": "^0.3.0-alpha.3",
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
